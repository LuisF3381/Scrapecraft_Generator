# =============================================================================
# Variables de entorno — ScrapeCraft
#
# Copia este archivo como .env y completa los valores que necesites.
# El .env NUNCA debe commitearse al repositorio (ya esta en .gitignore).
#
# Uso:
#   cp .env.example .env
#   # Editar .env con los valores reales
# ===========================================================================

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Nivel de detalle de los logs.
# Opciones: DEBUG, INFO, WARNING, ERROR  (default: INFO)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# DRIVER — aplicado a todos los jobs que lean estas variables
# Cada job lee estas variables desde su settings.py via os.environ.get()
# -----------------------------------------------------------------------------

# Proxy del browser en formato ip:puerto
# Dejar vacio para no usar proxy
# Ejemplo: SCRAPER_PROXY=123.45.67.89:8080
SCRAPER_PROXY=

# User-Agent personalizado del browser
# Dejar vacio para usar el User-Agent por defecto de Chrome
# Ejemplo: SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SCRAPER_USER_AGENT=
