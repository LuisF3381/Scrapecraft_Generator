# =============================================================================
# Pipeline: ejecucion {{ "paralela" if parallel else "serial" }} con consolidacion final
#
# Ejecutar con:
#   python -m src.main --pipeline config/pipelines/pipeline_consolidado.yaml
#
# Flujo:
{% for job in jobs %}
#   {{ loop.index }}. Ejecuta {{ job }} → output/{{ job }}/
{% endfor %}
#   {{ jobs | length + 1 }}. Si TODOS los jobs son exitosos → consolida en output/consolidados/
#
# Nota: la consolidacion se omite si alguno de los jobs falla.
# =============================================================================

# =========================================================================
# ZONA DATA ENGINEER — ajustar params y configuracion de consolidacion
# =========================================================================

name: {{ project_name }}_consolidado
description: "Pipeline {{ "paralelo" if parallel else "serial" }} con consolidacion de {{ project_name }}"
{% if parallel %}
parallel: true              # Los jobs se ejecutan simultaneamente con ThreadPoolExecutor
{% else %}
# parallel: true            # Descomentar para ejecutar los jobs en paralelo (simultaneamente)
{% endif %}

jobs:
{% for job in jobs %}
  - name: {{ job }}
    # params:           # Opcional: parametros especificos del job (tipos YAML nativos)
    #   clave: valor
    # enabled: false    # Descomentar para desactivar este job sin eliminarlo del pipeline
    # schedule:         # Opcional: ejecutar solo en fechas concretas (omitir = siempre)
    #   day_of_month: 3 #   solo el dia 3 de cada mes (1-31)
    #   day_of_week: 0  #   solo los lunes (0=lunes...6=domingo; combinable con day_of_month)
{% endfor %}

consolidate:
  enabled: true
  module: consolidador        # src/consolidadores/consolidador.py
  format: csv                 # todos los jobs deben incluir "csv" en output_formats
  params: {}                  # Opcional: parametros adicionales para el consolidador
