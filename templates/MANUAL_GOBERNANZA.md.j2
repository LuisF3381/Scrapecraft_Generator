## Ejemplo completo

```python
import logging
import pandas as pd

logger = logging.getLogger(__name__)


def validate(df: pd.DataFrame) -> list[str]:
    errors: list[str] = []

    # 1. Minimo de registros
    if len(df) < 10:
        errors.append(f"Solo {len(df)} registros. Posible bloqueo o cambio en la web.")

    # 2. Nulos en campo clave
    if "Titulo" in df.columns:
        nulos = df["Titulo"].isna() | (df["Titulo"].str.strip() == "")
        if nulos.sum() > 0:
            errors.append(f"'Titulo' tiene {int(nulos.sum())} valores vacios.")

    # 3. Tipo de dato
    if "Precio" in df.columns:
        no_num = pd.to_numeric(df["Precio"], errors="coerce").isna() & df["Precio"].notna()
        if no_num.sum() > 0:
            errors.append(f"'Precio' tiene {int(no_num.sum())} valores no numericos.")

    # 4. Rango
    if "Precio" in df.columns:
        precios = pd.to_numeric(df["Precio"], errors="coerce")
        if (precios <= 0).sum() > 0:
            logger.warning(f"'Precio' tiene {int((precios <= 0).sum())} valores <= 0.")

    # 5. Duplicados
    if "Titulo" in df.columns:
        n = int(df.duplicated(subset=["Titulo"], keep=False).sum())
        if n > 0:
            errors.append(f"{n} registros duplicados por 'Titulo'.")

    return errors
```

